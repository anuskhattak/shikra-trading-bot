# MT5 Account Credentials
# Copy this file to .env and fill in real values — never commit .env to git
MT5_ACCOUNT=12345678          # your broker account number (integer)
MT5_PASSWORD=your_password    # your broker password (never log or print this)
MT5_SERVER=BrokerName-Live    # broker server name from MT5 terminal

# Risk Parameters
RISK_PER_TRADE=1.0          # percentage, e.g. 1.0 = 1%
MAX_DAILY_DRAWDOWN=5.0      # percentage, e.g. 5.0 = 5%
MAX_OPEN_POSITIONS=3
MIN_RISK_REWARD=2.0         # minimum R:R ratio

# ML Model
ML_CONFIDENCE_THRESHOLD=0.65

# Logging
LOG_LEVEL=INFO
